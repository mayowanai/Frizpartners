# ────────────────────────────────────────────────────────────
#  ASSI from Korea — 외부 API 키 (선택)
#  .env.local 로 복사 후 채우세요. 비어 있으면 Mock 데이터로 자동 폴백됩니다.
# ────────────────────────────────────────────────────────────

# YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Instagram Basic Display API
INSTAGRAM_ACCESS_TOKEN=

# 뉴스 / 구글 트렌드 RSS (예: 구글 뉴스 RSS)
NEWS_RSS_URL=https://news.google.com/rss/search?q=K-Beauty%20%EB%B7%B0%ED%8B%B0&hl=ko&gl=KR&ceid=KR:ko

# 사이트 기준 URL (Route Handler self-fetch 용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
