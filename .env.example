# ────────────────────────────────────────────────────────────
#  ASSI from Korea — 환경변수
#  .env.local 로 복사 후 채우세요. (운영값은 Vercel 대시보드/CLI 로 설정)
# ────────────────────────────────────────────────────────────

# ── 인증 (Auth.js) ──────────────────────────────
# 세션 암호화 키. 생성: openssl rand -base64 32  또는  npx auth secret
AUTH_SECRET=

# ── 데이터베이스 (Vercel Postgres) ───────────────
# Vercel에서 Postgres 생성 시 자동 주입됩니다. 로컬은 `vercel env pull` 로 받으세요.
POSTGRES_URL=

# ── 소셜 로그인 (선택 — 없으면 버튼 비활성) ───────
# Google Cloud → OAuth 클라이언트 ID/비밀번호
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Kakao Developers → REST API 키 / Client Secret
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=

# ── 뷰티 트렌드 외부 API ─────────────────────────
# YouTube Data API v3 (키워드 검색)
YOUTUBE_API_KEY=
YOUTUBE_SEARCH_QUERY=K뷰티 신상 리뷰

# Instagram Basic Display API (선택)
INSTAGRAM_ACCESS_TOKEN=

# 뉴스 / 구글 트렌드 RSS (선택)
NEWS_RSS_URL=https://news.google.com/rss/search?q=K-Beauty%20%EB%B7%B0%ED%8B%B0&hl=ko&gl=KR&ceid=KR:ko
