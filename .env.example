# ────────────────────────────────────────────────────────────
#  ASSI from Korea — 환경변수
#  .env.local 로 복사 후 채우세요. (운영값은 Vercel 대시보드/CLI 로 설정)
# ────────────────────────────────────────────────────────────

# ── 인증 & DB (Supabase) ─────────────────────────
# Supabase 대시보드 → Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 소셜 로그인 버튼 활성화 (Supabase Google 프로바이더 설정 후 true 로) ──
NEXT_PUBLIC_GOOGLE_ENABLED=

# ── 뷰티 트렌드 외부 API ─────────────────────────
# YouTube Data API v3 (키워드 검색)
YOUTUBE_API_KEY=
YOUTUBE_SEARCH_QUERY=K뷰티 신상 리뷰

# Instagram Basic Display API (선택)
INSTAGRAM_ACCESS_TOKEN=

# 뉴스 / 구글 트렌드 RSS (선택)
NEWS_RSS_URL=https://news.google.com/rss/search?q=K-Beauty%20%EB%B7%B0%ED%8B%B0&hl=ko&gl=KR&ceid=KR:ko
